@using MudBlazor
@inject CustomAuthStateProvider MyStateProvider

<style>
    .page{
        background-color: @getColorUI;
    }
</style>

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">EshopWebBlazor</a>
        <p>Made by Trueraqe</p>
        <button title="Navigation menu" class="navbar-toggler" @onclick="ToggleNavMenu">
            <span class="navbar-toggler-icon"></span>
        </button>
    </div>
</div>

<div class="@NavMenuCssClass nav-scrollable" @onclick="ToggleNavMenu">
    <MudColorPicker @bind-Text="setColorUI" Variant="Variant.Filled" Label="Zmień kolor UI" />
    <MudButton Class="button" Variant="Variant.Filled" OnClick="changeColor">Zapisz</MudButton>
    <MudButton Class="button" Variant="Variant.Filled" OnClick="resetColor">Resetuj</MudButton>
    @* <nav class="nav flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> Home
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="counter">
                <span class="bi bi-plus-square-fill-nav-menu" aria-hidden="true"></span> Counter
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="weather">
                <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> Weather
            </NavLink>
        </div>
    </nav> *@
</div>

@code {
    private bool collapseNavMenu = true;

    private string? NavMenuCssClass => collapseNavMenu ? "collapse" : null;

    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
    }

    private string setColorUI;
    private string getColorUI = null!;

    protected override async Task OnInitializedAsync()
    {
        getColorUI = await MyStateProvider.GetColorUI();
    }
    public async Task changeColor()
    {
        await MyStateProvider.SetColorUI(setColorUI);

        getColorUI = await MyStateProvider.GetColorUI();
        await OnInitializedAsync();
    }
    public async Task resetColor()
    {
        getColorUI = await MyStateProvider.ResetColorUI();
        await OnInitializedAsync();
    }
}
